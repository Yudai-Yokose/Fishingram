<div class="max-w-md mx-auto mt-10 p-6 bg-base-100 rounded-lg shadow-lg bg-opacity-70">
  <h2 class="text-3xl font-bold mb-6 text-center animate-fade-in" style="animation-delay: 0s;">プロフィール編集</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6", multipart: true }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="relative flex justify-center animate-fade-in" style="animation-delay: 0.2s;">
      <%= image_tag resource.image_url, class: "rounded-full w-24 h-24 object-cover" %>
    </div>
    
    <div class="form-control animate-fade-in" style="animation-delay: 0.4s;">
      <div class="relative flex items-center justify-center">
        <%= f.file_field :image, class: "file-input file-input-bordered w-full max-w-xs", id: "profile_image_input" %>
      </div>
    </div>

    <div class="form-control animate-fade-in" style="animation-delay: 1s;">
      <div class="relative flex items-center">
        <%= f.label :name, class: "absolute left-0 inset-y-0 flex items-center pl-3" do %>
          <i class="fas fa-user text-gray-400"></i>
        <% end %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "input input-bordered pl-10 w-full", placeholder: "Name" %>
      </div>
    </div>

    <div class="form-control animate-fade-in" style="animation-delay: 1.2s;">
      <div class="relative flex items-center">
        <%= f.label :email, class: "absolute left-0 inset-y-0 flex items-center pl-3" do %>
          <i class="fas fa-envelope text-gray-400"></i>
        <% end %>
        <%= f.email_field :email, autocomplete: "email", class: "input input-bordered pl-10 w-full", placeholder: "Email" %>
      </div>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div class="text-sm text-gray-500 animate-fade-in" style="animation-delay: 1.4s;">
        Currently waiting confirmation for: <%= resource.unconfirmed_email %>
      </div>
    <% end %>

    <div class="form-control mt-6 animate-fade-in" style="animation-delay: 1.8s;">
      <%= f.submit "変更を保存", class: "btn btn-outline btn-primary w-full" %>
    </div>
  <% end %>

  <div class="my-8 animate-slide-in" style="animation-delay: 1.2s;">
    <hr class="border-gray-500">
  </div>

  <div class="text-center animate-fade-in" style="animation-delay: 2.2s;">
    <%= button_to "アカウント削除", registration_path(resource_name), data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete, class: "btn btn-primary btn-danger w-full" %>
  </div>
</div>