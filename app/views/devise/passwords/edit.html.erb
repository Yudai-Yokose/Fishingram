<div class="max-w-md mx-auto mt-10 p-6 bg-base-100 rounded-lg shadow-lg bg-opacity-70">
  <div class="form-control mt-6 animate-fade-in" style="animation-delay: 0s;">パスワード再設定を行います。</h3>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <div class="form-control animate-fade-in" style="animation-delay: 0.2s;">
      <div class="relative">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3">
          <i class="fas fa-lock text-gray-400"></i>
        </span>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "input input-bordered pl-10 w-full", placeholder: "新しいパスワード (英数4字以上)" %>
      </div>
    </div>

    <div class="form-control animate-fade-in" style="animation-delay: 0.4s;">
      <div class="relative">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3">
          <i class="fas fa-lock text-gray-400"></i>
        </span>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input input-bordered pl-10 w-full", placeholder: "パスワード (確認用)" %>
      </div>
    </div>

    <div class="form-control mt-6 animate-fade-in" style="animation-delay: 0.6s;">
      <%= f.submit "パスワードを変更する", class: "btn btn-outline btn-primary w-full" %>
    </div>
  <% end %>

  <div class="my-10 animate-slide-in" style="animation-delay: 0.8s;">
    <hr class="border-gray-500">
  </div>

  <div class="text-center animate-fade-in" style="margin-top: -20px; animation-delay: 1s;">
    <%= link_to "ログインページに戻る", new_session_path(resource_name) %>
  </div>
</div>