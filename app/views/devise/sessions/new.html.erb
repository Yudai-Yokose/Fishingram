<div class="max-w-md mx-auto mt-10 p-6 bg-base-100 rounded-lg shadow-lg bg-opacity-70">
  <h3 class="text-3xl font-bold mb-6 text-center animate-fade-in" style="animation-delay: 0s;">Log in</h3>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="form-control animate-fade-in" style="animation-delay: 0.2s;">
      <div class="relative">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3">
          <i class="fas fa-envelope text-gray-400"></i>
        </span>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered pl-10 w-full", placeholder: "Email" %>
      </div>
    </div>

    <div class="form-control animate-fade-in" style="animation-delay: 0.4s;">
      <div class="relative">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3">
          <i class="fas fa-lock text-gray-400"></i>
        </span>
        <%= f.password_field :password, autocomplete: "current-password", class: "input input-bordered pl-10 w-full", placeholder: "パスワード" %>
      </div>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="form-control animate-fade-in" style="animation-delay: 0.6s;">
        <label class="cursor-pointer label flex items-center justify-start">
          <%= f.check_box :remember_me, class: "checkbox checkbox-primary" %>
          <span class="label-text ml-2">ログイン状態を保持</span>
        </label>
      </div>
    <% end %>

    <div class="form-control mt-6 animate-fade-in" style="animation-delay: 0.8s;">
      <%= f.submit "ログイン", class: "btn btn-outline btn-primary w-full" %>
    </div>
  <% end %>

  <div class="my-10 animate-slide-in" style="animation-delay: 1s;">
    <hr class="border-gray-500">
  </div>

  <div class="text-center animate-fade-in" style="margin-top: -20px; animation-delay: 1.2s;">
    <%= link_to "パスワードを忘れた方", new_password_path(resource_name) %><br>
    <%= link_to "アカウントをお持ちでない方", new_registration_path(resource_name) %>
  </div>
</div>