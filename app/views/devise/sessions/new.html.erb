<div class="max-w-md mx-auto mt-10 p-6 bg-base-100 rounded-lg shadow-lg bg-opacity-70">
  <h3 class="text-3xl font-bold mb-6 text-center animate-fade-in" style="animation-delay: 0s;">Log in</h3>
  
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <div class="form-control animate-fade-in" style="animation-delay: 0.2s;">
      <div class="relative">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3">
          <i class="fas fa-envelope text-gray-400"></i>
        </span>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered pl-10 w-full", placeholder: "Email" %>
      </div>
    </div>

    <div class="form-control animate-fade-in" style="animation-delay: 0.4s;">
      <div class="relative">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3">
          <i class="fas fa-lock text-gray-400"></i>
        </span>
        <%= f.password_field :password, autocomplete: "current-password", class: "input input-bordered pl-10 w-full", placeholder: "パスワード" %>
      </div>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="form-control animate-fade-in" style="animation-delay: 0.6s;">
        <label class="cursor-pointer label flex items-center justify-start">
          <%= f.check_box :remember_me, class: "checkbox checkbox-primary" %>
          <span class="label-text ml-2">ログイン状態を保持</span>
        </label>
      </div>
    <% end %>

    <div class="form-control mt-6 animate-fade-in" style="animation-delay: 0.8s;">
      <%= f.submit "ログイン", class: "btn btn-outline btn-primary w-full" %>
    </div>
  <% end %>

  <div class="relative text-left animate-fade-in text-white mb-1 mt-6" style="animation-delay: 0.9s;">
    <span>または</span>
  </div>

  <div class="my-1 animate-slide-in" style="animation-delay: 1s;">
    <hr class="border-gray-500">
  </div>

  <div class="flex justify-center my-6 animate-fade-in" style="animation-delay: 1.2s;">
    <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "gsi-material-button" do %>
      <div class="gsi-material-button-state"></div>
      <div class="gsi-material-button-content-wrapper">
        <div class="gsi-material-button-icon">
          <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" xmlns:xlink="http://www.w3.org/1999/xlink" style="display: block;">
            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"></path>
            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"></path>
            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"></path>
            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"></path>
            <path fill="none" d="M0 0h48v48H0z"></path>
          </svg>
        </div>
        <span class="gsi-material-button-contents">Sign in with Google</span>
        <span style="display: none;">Sign in with Google</span>
      </div>
    <% end %>
  </div>

  <div class="my-6 animate-slide-in" style="animation-delay: 1.4s;">
    <hr class="border-gray-500">
  </div>

  <div class="text-center animate-fade-in" style="margin-top: 20px; animation-delay: 1.6s;">
    <%= link_to "パスワードを忘れた方", new_password_path(resource_name) %><br>
    <%= link_to "アカウントをお持ちでない方", new_registration_path(resource_name) %>
  </div>
</div>