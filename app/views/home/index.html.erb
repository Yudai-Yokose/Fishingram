<div class="intro text-center flex items-center justify-center min-h-[50vh] hidden">
  <div class="intro-message">
    <h1 class="text-4xl font-bold text-white">Welcome to Fishingram</h1>
    <p class="mt-2 text-xl text-gray-300">さぁ記録しよう、より手軽に。</p>
  </div>
</div>

<section class="pt-10 pb-6 hidden">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <div class="feature p-2 text-white rounded-lg flex items-center transform transition duration-500 hover:scale-105">
        <div class="icon bg-yellow-500 text-white rounded-full p-2 flex items-center justify-center mr-3">
          <i class="fas fa-lightbulb fa-2x"></i> <!-- 黄色のランプのアイコン -->
        </div>
        <div>
          <p class="text-lg">Fishingramは手軽に釣果を記録することができるサービスです。</p>
        </div>
      </div>
      <div class="feature p-2 text-white rounded-lg flex flex-col items-start transform transition duration-500 hover:scale-105">
        <p class="text-2xl font-bold">主な機能</p>
        <div class="line mt-1 mb-1"></div>
      </div>
      <div class="feature p-2 text-white rounded-lg flex items-center transform transition duration-500 hover:scale-105">
        <div class="icon bg-blue-500 text-white rounded-full p-2 flex items-center justify-center mr-3">
          <i class="fas fa-camera fa-2x"></i>
        </div>
        <div>
          <p class="text-lg">写真と一緒に潮位や魚のサイズを簡単に記録できます。</p>
        </div>
      </div>
      <div class="feature p-2 text-white rounded-lg flex items-center transform transition duration-500 hover:scale-105">
        <div class="icon bg-green-500 text-white rounded-full p-2 flex items-center justify-center mr-3">
          <i class="fas fa-book fa-2x"></i>
        </div>
        <div>
          <p class="text-lg">自分しか見れない日記機能で、手軽に釣行の振り返りができます。</p>
        </div>
      </div>
      <div class="feature p-2 text-white rounded-lg flex flex-col items-start transform transition duration-500 hover:scale-105">
        <div class="flex items-center mb-3">
          <div class="icon bg-red-500 text-white rounded-full p-2 flex items-center justify-center mr-3">
            <i class="fas fa-search fa-2x"></i> <!-- 赤のアイコン -->
          </div>
          <div>
            <p class="text-lg">みんなの釣果を覗き、コメント機能で交流もできます。</p>
          </div>
        </div>
        <div class="line mt-6 mb-2 w-full"></div>
      </div>
      <div class="feature p-2 text-white rounded-lg flex items-center transform transition duration-500 hover:scale-105">
        <div class="icon bg-yellow-500 text-white rounded-full p-2 flex items-center justify-center mr-3">
          <i class="fas fa-lightbulb fa-2x"></i> <!-- 黄色のランプのアイコン -->
        </div>
        <div>
          <p class="text-lg">下の「Record」から、みんなの釣果を覗いてみましょう。</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const intro = document.querySelector('.intro');
    const features = document.querySelectorAll('.feature');
    const section = document.querySelector('section');

    // Slide up the intro message when the page loads
    intro.classList.remove('hidden');
    intro.classList.add('slide-up');

    // Fade out the intro message after 3 seconds
    setTimeout(() => {
      intro.classList.add('fade-out');
    }, 3000);

    // Slide up the features after the intro message
    setTimeout(() => {
      intro.classList.add('hidden');
      section.classList.remove('hidden');
      features.forEach((feature, index) => {
        feature.classList.add('hidden');
        setTimeout(() => {
          feature.classList.remove('hidden');
          feature.classList.add('slide-up');
        }, index * 300); // Add a delay of 0.3 seconds between each feature
      });
    }, 4000); // Start sliding up the features after the intro message has faded out
  });
</script>